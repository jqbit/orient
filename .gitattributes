# Normalize line endings: text files use LF in the repo, native on checkout.
* text=auto eol=lf

# Markdown is the project's primary language; make sure GitHub renders it
# correctly and counts it on the language bar.
*.md text linguist-language=Markdown
*.md linguist-detectable=true

# YAML config files
*.yml text
*.yaml text
*.json text

# Things that should never receive line-ending normalization.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
